1d:["$","div",null,{"style":{"borderTop":"1px solid var(--line)","paddingTop":12},"children":[["$","div",null,{"className":"t-body","style":{"fontSize":"0.875rem","fontStyle":"italic","color":"var(--ink)","lineHeight":1.6,"marginBottom":6},"children":["“","Mr. Market is there to serve you, not to guide you. It is his pocketbook, not his wisdom, that you will find useful.","”"]}],["$","div",null,{"className":"t-micro","children":"Benjamin Graham, The Intelligent Investor"}]]}]
1e:["$","details","economic-moat",{"className":"card","style":{"borderLeft":"3px solid var(--bull)","padding":0},"children":[["$","summary",null,{"style":{"padding":"16px","cursor":"pointer","listStyle":"none","display":"flex","justifyContent":"space-between","alignItems":"flex-start","gap":12,"minHeight":44},"children":[["$","div",null,{"style":{"flex":1},"children":[["$","div",null,{"className":"t-body","style":{"fontWeight":700,"color":"var(--bull)"},"children":"Economic Moat"}],["$","div",null,{"className":"t-micro","style":{"marginTop":2},"children":"Buffett's competitive advantage framework"}]]}],["$","div",null,{"style":{"color":"var(--muted)","fontSize":"0.75rem","fontFamily":"var(--font-mono)","marginTop":2,"flexShrink":0},"children":"▾"}]]}],["$","div",null,{"style":{"padding":"0 16px 16px","borderTop":"1px solid var(--line)"},"children":[["$","div",null,{"className":"t-body","style":{"marginTop":14,"lineHeight":1.6},"children":"A sustainable business advantage that protects a company from competition the way a moat protects a castle. Without a moat, any profit eventually attracts competition until it disappears."}],["$","div",null,{"style":{"background":"var(--bg-hover)","padding":"10px 12px","margin":"12px 0","borderLeft":"2px solid var(--bull)"},"children":[["$","div",null,{"className":"t-micro","style":{"color":"var(--bull)","marginBottom":4},"children":"HOW TO APPLY"}],["$","div",null,{"className":"t-body","style":{"fontSize":"0.875rem","color":"var(--muted)"},"children":"4 moat types: Cost Advantage, Switching Costs, Network Effect, Intangible Assets (brand, patent, license). Wide moat = durable profit for 10+ years."}]]}],["$","div",null,{"className":"t-body","style":{"fontSize":"0.875rem","color":"var(--muted)","lineHeight":1.6,"marginBottom":12},"children":"Thai examples: ADVANC has switching costs (you rarely change your phone carrier). AOT (Airports of Thailand) has regulatory scale — nobody builds a competing international airport. CPALL has network effects across 14,000+ 7-Eleven stores. These moats are why Buffett prefers holding periods of 10+ years."}],["$","div",null,{"style":{"borderTop":"1px solid var(--line)","paddingTop":12},"children":[["$","div",null,{"className":"t-body","style":{"fontSize":"0.875rem","fontStyle":"italic","color":"var(--ink)","lineHeight":1.6,"marginBottom":6},"children":["“","The key to investing is not assessing how much an industry is going to affect society, or how much it will grow, but rather determining the competitive advantage of any given company and, above all, the durability of that advantage.","”"]}],["$","div",null,{"className":"t-micro","children":"Warren Buffett, Fortune Magazine, 1999"}]]}]]}]]}]
1f:["$","details","cape-ratio",{"className":"card","style":{"borderLeft":"3px solid var(--caution)","padding":0},"children":[["$","summary",null,{"style":{"padding":"16px","cursor":"pointer","listStyle":"none","display":"flex","justifyContent":"space-between","alignItems":"flex-start","gap":12,"minHeight":44},"children":[["$","div",null,{"style":{"flex":1},"children":[["$","div",null,{"className":"t-body","style":{"fontWeight":700,"color":"var(--caution)"},"children":"Shiller CAPE Ratio"}],["$","div",null,{"className":"t-micro","style":{"marginTop":2},"children":"The 10-year market valuation signal"}]]}],["$","div",null,{"style":{"color":"var(--muted)","fontSize":"0.75rem","fontFamily":"var(--font-mono)","marginTop":2,"flexShrink":0},"children":"▾"}]]}],["$","div",null,{"style":{"padding":"0 16px 16px","borderTop":"1px solid var(--line)"},"children":[["$","div",null,{"className":"t-body","style":{"marginTop":14,"lineHeight":1.6},"children":"CAPE (Cyclically Adjusted P/E) divides the S&P 500 price by its average earnings over the past 10 years, adjusted for inflation. High CAPE = expensive market = poor future 10-year returns."}],["$","div",null,{"style":{"background":"var(--bg-hover)","padding":"10px 12px","margin":"12px 0","borderLeft":"2px solid var(--caution)"},"children":[["$","div",null,{"className":"t-micro","style":{"color":"var(--caution)","marginBottom":4},"children":"HOW TO APPLY"}],["$","div",null,{"className":"t-body","style":{"fontSize":"0.875rem","color":"var(--muted)"},"children":"Current CAPE: 34.2 (historical median: 16). Levels above 35 have historically preceded corrections."}]]}],["$","div",null,{"className":"t-body","style":{"fontSize":"0.875rem","color":"var(--muted)","lineHeight":1.6,"marginBottom":12},"children":"CAPE above 30 has historically predicted poor 10-year forward returns (2–4% per year). CAPE below 15 has predicted excellent returns (10–12% per year). At 34.2, the US market is expensive by this measure. Thailand's SET P/E at 15.4 is closer to fair value — which is partly why SET may outperform US stocks over the next decade."}],["$","div",null,{"style":{"borderTop":"1px solid var(--line)","paddingTop":12},"children":[["$","div",null,{"className":"t-body","style":{"fontSize":"0.875rem","fontStyle":"italic","color":"var(--ink)","lineHeight":1.6,"marginBottom":6},"children":["“","The stock market is filled with individuals who know the price of everything, but the value of nothing.","”"]}],["$","div",null,{"className":"t-micro","children":"Philip Fisher (via Warren Buffett)"}]]}]]}]]}]
20:["$","details","circle-of-competence",{"className":"card","style":{"borderLeft":"3px solid var(--tech)","padding":0},"children":[["$","summary",null,{"style":{"padding":"16px","cursor":"pointer","listStyle":"none","display":"flex","justifyContent":"space-between","alignItems":"flex-start","gap":12,"minHeight":44},"children":[["$","div",null,{"style":{"flex":1},"children":[["$","div",null,{"className":"t-body","style":{"fontWeight":700,"color":"var(--tech)"},"children":"Circle of Competence"}],["$","div",null,{"className":"t-micro","style":{"marginTop":2},"children":"Munger's risk management principle"}]]}],["$","div",null,{"style":{"color":"var(--muted)","fontSize":"0.75rem","fontFamily":"var(--font-mono)","marginTop":2,"flexShrink":0},"children":"▾"}]]}],["$","div",null,{"style":{"padding":"0 16px 16px","borderTop":"1px solid var(--line)"},"children":[["$","div",null,{"className":"t-body","style":{"marginTop":14,"lineHeight":1.6},"children":"Only invest in businesses you deeply understand. If you cannot explain how a company makes money in two minutes, it is outside your circle — and you are betting, not investing."}],["$","div",null,{"style":{"background":"var(--bg-hover)","padding":"10px 12px","margin":"12px 0","borderLeft":"2px solid var(--tech)"},"children":[["$","div",null,{"className":"t-micro","style":{"color":"var(--tech)","marginBottom":4},"children":"HOW TO APPLY"}],["$","div",null,{"className":"t-body","style":{"fontSize":"0.875rem","color":"var(--muted)"},"children":"Start with industries you know: retail, banking, telecom, real estate. Add others only after you understand their economics."}]]}],["$","div",null,{"className":"t-body","style":{"fontSize":"0.875rem","color":"var(--muted)","lineHeight":1.6,"marginBottom":12},"children":"Munger's version of this: avoiding known failure modes is more reliable than finding unknown success. If you use 7-Eleven every day, you have an edge in understanding CPALL's business. If you have a KBank account, you understand retail banking better than most analysts who have never lived in Thailand. Start in your circle, expand it slowly."}],["$","div",null,{"style":{"borderTop":"1px solid var(--line)","paddingTop":12},"children":[["$","div",null,{"className":"t-body","style":{"fontSize":"0.875rem","fontStyle":"italic","color":"var(--ink)","lineHeight":1.6,"marginBottom":6},"children":["“","All I want to know is where I'm going to die, so I'll never go there.","”"]}],["$","div",null,{"className":"t-micro","children":"Charlie Munger"}]]}]]}]]}]
